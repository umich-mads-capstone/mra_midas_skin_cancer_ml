            def prepare_model_for_inference(model, num_classes):
                """Adjust the final classification head to match checkpoint output classes."""
                if hasattr(model, "heads") and isinstance(model.heads, nn.Sequential):
                    num_feats = model.heads[-1].in_features
                    model.heads[-1] = nn.Linear(in_features=num_feats, out_features=num_classes)
                elif hasattr(model, "fc"):
                    num_feats = model.fc.in_features
                    model.fc = nn.Linear(in_features=num_feats, out_features=num_classes)
                elif hasattr(model, "classifier"):
                    if isinstance(model.classifier, nn.Linear):
                        num_feats = model.classifier.in_features
                        model.classifier = nn.Linear(in_features=num_feats, out_features=num_classes)
                    else:
                        num_feats = model.classifier[-1].in_features
                        model.classifier[-1] = nn.Linear(in_features=num_feats, out_features=num_classes)
                else:
                    raise ValueError("Unable to identify model classification head for inference setup.")

                return model


            def export_predictions_for_split(
                model,
                dataloader,
                class_names,
                checkpoint_path,
                output_dir,
                split_name,
                threshold=0.4,
            ):
                """Run inference on one split and save predictions with the same schema used for test export."""
                set_seeds()

                device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
                model = prepare_model_for_inference(model, num_classes=len(class_names))
                model.load_state_dict(torch.load(checkpoint_path, map_location=device))
                model.to(device)
                model.eval()

                all_preds = []
                all_labels = []
                all_probs = []
                all_file_names = []

                positive_class_idx = 1
                positive_class_name = class_names[positive_class_idx]

                with torch.no_grad():
                    for inputs, labels, file_names, _ in dataloader:
                        inputs = inputs.to(device)
                        labels = labels.to(device)

                        outputs = model(inputs)
                        probs = F.softmax(outputs, dim=1)

                        preds = (probs[:, positive_class_idx] >= threshold).long()

                        all_preds.extend(preds.cpu().numpy())
                        all_labels.extend(labels.cpu().numpy())
                        all_probs.extend(probs[:, positive_class_idx].cpu().numpy())
                        all_file_names.extend(file_names)

                pred_labels = [class_names[p] for p in all_preds]
                actual_labels = [class_names[l] for l in all_labels]

                results_df = pd.DataFrame(
                    {
                        "file_name": all_file_names,
                        f"{positive_class_name}_probability": all_probs,
                        "prediction_label": pred_labels,
                        "actual_label": actual_labels,
                    }
                )

                out_stem = Path(checkpoint_path).stem
                out_dir = Path(output_dir)
                out_dir.mkdir(parents=True, exist_ok=True)

                out_path = out_dir / f"{out_stem}_{split_name}_predictions.xlsx"
                results_df.to_excel(out_path, index=False)

                accuracy = (np.array(all_preds) == np.array(all_labels)).mean() * 100
                print(f"{split_name.capitalize()} Accuracy: {accuracy:.2f}%")
                print(f"Saved {split_name} predictions to: {out_path.resolve()}")


            def export_predictions_from_saved_weights(
                model_name="resnet18",
                image_dists=("1ft", "6in", "dscope"),
                image_output_folder=OUTPUT_DIR,
                threshold=0.4,
                best_checkpoint_map=None,
            ):
                """
                Loads fixed saved checkpoints and exports train/val/test predictions without retraining.
                """
                for image_dist in image_dists:
                    print(f"\n=== Processing image distance: {image_dist} ===")

                    model, model_weights = get_model(model_name)

                    _, _, _, dataloaders, _, _ = transform_load_img(
                        INPUT_DIR / image_dist,
                        weights=model_weights,
                        use_oversampling=False,
                    )

                    checkpoint_dir = Path(image_output_folder) / image_dist
                    checkpoint_name = best_checkpoint_map.get(image_dist)

                    checkpoint_path = checkpoint_dir / checkpoint_name
                    if not checkpoint_path.exists():
                        raise FileNotFoundError(f"Checkpoint not found: {checkpoint_path}")

                    print(f"Using fixed checkpoint: {checkpoint_path}")

                    class_names = dataloaders["test"].dataset.classes
                    for split_name in ("train", "val", "test"):
                        export_predictions_for_split(
                            model=model,
                            dataloader=dataloaders[split_name],
                            class_names=class_names,
                            checkpoint_path=checkpoint_path,
                            output_dir=checkpoint_dir,
                            split_name=split_name,
                            threshold=threshold,
                        )


            # Fixed best-model checkpoints per image distance.

            BEST_CHECKPOINTS = {
                "1ft": "ResNet_20260309_222933.pt",
                "6in": "ResNet_20260309_223847.pt",
                "dscope": "ResNet_20260309_222158.pt",
            }


            export_predictions_from_saved_weights(
                model_name="resnet18",
                image_dists=("dscope",),
                image_output_folder="/work/image_model_output",
                threshold=0.4,
                best_checkpoint_map=BEST_CHECKPOINTS,
            )


            export_predictions_from_saved_weights(
                model_name="resnext50_32x4d",
                image_dists=("1ft", "6in"),
                image_output_folder="/work/image_model_output",
                threshold=0.4,
                best_checkpoint_map=BEST_CHECKPOINTS,
            )
