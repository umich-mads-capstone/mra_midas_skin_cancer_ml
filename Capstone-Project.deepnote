        - id: d1b049c53fd944d299237ecfa486e175
          blockGroup: 3389b27b25234db6bf045311bd85d714
          sortingKey: "000045"
          contentHash: e48a2be4
          executionFinishedAt: 2026-03-14T20:09:56.533Z
          executionStartedAt: 2026-03-14T20:09:56.533Z
          type: code
          content: >-
            def fit_and_predict_final_model(
                df,
                *,
                best_svd=9,
                best_C=1,
                text_col=text_col,
                target_col=target_col,
                split_col=split_col,
                id_cols=id_cols,
            ):

                """"
                Generate predictions for the entire dataset (train/val/test) without retraining
                """

                 # Train final best model on training data
                clf, pipe_text = train_final_model(
                    df,
                    best_svd=best_svd,
                    best_C=best_C
                )

                # Create SVD features for the entire dataset using pretrained SVDs
                full_df = apply_note_embeddings_tfidf_svd(
                    df.copy(),
                    pipe_text,
                    text_col=text_col,
                    out_prefix="note_svd"
                )

                # Recreate model feature matrix
                drop_cols = list(id_cols) + [target_col, split_col, text_col]
                X_full = full_df.drop(columns=drop_cols, errors="ignore")

                # Predictions
                malignant_probability = clf.predict_proba(X_full)[:, 1]
                prediction_label = (malignant_probability >= 0.5).astype(int)

                # Final dataframe
                prediction_df = full_df[
                    ["lesion_key", "midas_path_binary", split_col]
                ].copy()

                prediction_df["malignant_probability"] = malignant_probability
                prediction_df["metadata_prediction_label"] = prediction_label

                label_map = {1: "malignant", 0: "benign"}

                prediction_df["midas_path_binary"] = prediction_df["midas_path_binary"].map(label_map)
                prediction_df["metadata_prediction_label"] = prediction_df["metadata_prediction_label"].map(label_map)

                # Export predictions to results folder
                # Create output directory if it doesn't exist
                output_dir = Path("metadata_model_outputs")
                output_dir.mkdir(parents=True, exist_ok=True)

                # Timestamp to avoid overwriting files
                timestamp = datetime.now().strftime("%Y%m%d_%H%M")

                # Export predictions
                prediction_df.to_excel(
                    output_dir / f"metadata_model_{timestamp}_predictions.xlsx",
                    index=False
                )


                print(f"Predictions saved to: {output_dir}")

                return clf, pipe_text, prediction_df
          metadata:
