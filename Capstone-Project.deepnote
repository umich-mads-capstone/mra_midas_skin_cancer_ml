          type: code
          content: >-
            def find_threshold_for_target_recall(
                clf,
                X,
                y,
                target_recall=0.9
            ):

                probs = clf.predict_proba(X)[:,1]

                precision, recall, thresholds = precision_recall_curve(y, probs)

                idx = np.where(recall >= target_recall)[0][-1]

                return thresholds[idx]
