          type: code
          content: >-
            # Move images to /tmp for high throughput access to train models

            # Refer to: https://deepnote.com/docs/importing-data-to-deepnote


            # 1️⃣ Clean old environment

            !rm -rf /tmp/mra_midas_skin_cancer_ml

            !rm -f /tmp/split_images.zip


            # 2️⃣ Recreate directory structure

            !mkdir -p /tmp/mra_midas_skin_cancer_ml/data/input

            !mkdir -p /tmp/mra_midas_skin_cancer_ml/data/output/1ft

            !mkdir -p /tmp/mra_midas_skin_cancer_ml/data/output/6in

            !mkdir -p /tmp/mra_midas_skin_cancer_ml/data/output/dscope


